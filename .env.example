# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Model name (provider-specific)
# Anthropic: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
# OpenAI:    gpt-4o, gpt-4o-mini
# Ollama:    llama3.1, qwen2.5, mistral
LLM_MODEL=claude-sonnet-4-6

# API keys (only the one for your chosen provider is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (sentence-transformers identifier)
# Smaller/faster: BAAI/bge-small-en-v1.5  (384-dim, ~130MB)
# Balanced:      BAAI/bge-base-en-v1.5   (768-dim, ~440MB)
# Best quality:  BAAI/bge-large-en-v1.5  (1024-dim, ~1.3GB)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Chunking
CHUNK_TOKENS=600
CHUNK_OVERLAP=80

# Retrieval
TOP_K_VECTOR=20
TOP_K_BM25=20
TOP_N_FINAL=6
CONTEXT_TOKEN_BUDGET=3000

# Flask
FLASK_SECRET_KEY=change-me
MAX_UPLOAD_MB=50
