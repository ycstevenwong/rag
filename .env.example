# LLM endpoint (self-hosted, Ollama-compatible HTTP API)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1
LLM_API_KEY=

# Embedding endpoint (defaults to LLM_BASE_URL if unset)
# bge-m3: multilingual, 1024-dim, 8k context
# bge-base-en-v1.5: English-only, 768-dim, 512 context
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=

# Chunking
CHUNK_TOKENS=600
CHUNK_OVERLAP=80

# Drop PDF text blocks whose max font size is >= this value (points). Useful
# for excluding document titles / page banners that look more like headers
# than body content. 0 = no filtering. Run scripts/inspect_pdf.py first to
# see your corpus's font distribution before picking a threshold.
PDF_MAX_FONT_SIZE=0

# Comma-separated font-family substrings (case-insensitive) that identify
# screen mockup text (e.g., CICS terminal screens in Monotony-Regular).
# Matching blocks get merged with consecutive matching blocks, are kept
# intact through chunking, and are flagged as contains_screen in the chunk
# meta. Empty = disabled.
PDF_SCREEN_FONTS=

# Retrieval
TOP_K_VECTOR=20
TOP_K_BM25=20
TOP_N_FINAL=10
CONTEXT_TOKEN_BUDGET=3000

# Flask
FLASK_SECRET_KEY=change-me
MAX_UPLOAD_MB=50

# Admin gate (leave both ADMIN_* values empty to disable login entirely).
# Generate ADMIN_PASSWORD_HASH with:
#   python -c "from werkzeug.security import generate_password_hash; \
#              import getpass; print(generate_password_hash(getpass.getpass()))"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_LIFETIME_HOURS=8

# Storage safety. Uploads return HTTP 507 ("Insufficient Storage") instead
# of crashing with Errno 28 when the data partition is low or the pending
# approval queue is full. Orphan files in data/uploads/ older than
# UPLOAD_ORPHAN_MAX_AGE (seconds) are cleared on app startup.
MIN_FREE_DISK_GB=1.0
PENDING_MAX_MB=1024
UPLOAD_ORPHAN_MAX_AGE=3600
